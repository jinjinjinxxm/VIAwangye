    <script>
        // API配置
        const API_KEY = '098aff643a684c8bac04f63452c5d1c1';
        const BASE_URL = 'https://p43dn5ygxt.re.qweatherapi.com/v7/weather/3d';
        const LOCATION_ID = '101190405'; // 吴中区
        
        // 天气图标映射
        const weatherIcons = {
            '晴': 'fa-sun',
            '多云': 'fa-cloud-sun',
            '阴': 'fa-cloud',
            '小雨': 'fa-cloud-rain',
            '中雨': 'fa-cloud-showers-heavy',
            '大雨': 'fa-cloud-showers-heavy',
            '暴雨': 'fa-cloud-showers-heavy',
            '雷阵雨': 'fa-bolt',
            '雪': 'fa-snowflake',
            '小雪': 'fa-snowflake',
            '中雪': 'fa-snowflake',
            '大雪': 'fa-snowflake',
            '雾': 'fa-smog',
            '霾': 'fa-smog',
            '沙尘': 'fa-wind',
            '浮尘': 'fa-wind'
        };
        
        // DOM元素
        const loader = document.getElementById('loader');
        const errorMessage = document.getElementById('errorMessage');
        
        // 获取并显示天气数据
        async function fetchWeatherData() {
            // 显示加载动画
            loader.classList.add('active');
            errorMessage.style.display = 'none';
            
            try {
                // 使用正确的查询参数格式
                const apiUrl = `${BASE_URL}?location=${LOCATION_ID}`;
                const response = await fetch(apiUrl, {
                    method: 'GET',
                    headers: {
                        'X-QW-Api-Key': API_KEY,
                        'Accept-Encoding': 'gzip',
                        'Accept': 'application/json'
                    }
                });
                
                if (!response.ok) {
                    throw new Error(`API请求失败: ${response.status}`);
                }
                
                const data = await response.json();
                
                // 检查数据有效性
                if (!data.daily || data.daily.length < 3) {
                    throw new Error('API返回数据不完整');
                }
                
                // 更新三天的天气预报
                for (let i = 0; i < 3; i++) {
                    const dayData = data.daily[i];
                    
                    // 更新天气描述
                    document.getElementById(`weatherDay${i}`).textContent = dayData.textDay;
                    
                    // 更新温度
                    document.getElementById(`minTempDay${i}`).textContent = dayData.tempMin + "°";
                    document.getElementById(`maxTempDay${i}`).textContent = dayData.tempMax + "°";
                    
                    // 更新天气图标
                    const iconClass = weatherIcons[dayData.textDay] || 'fa-cloud-sun';
                    document.querySelectorAll('.weather-icon')[i].innerHTML = `<i class="fas ${iconClass}"></i>`;
                }
                
                console.log('天气数据更新成功');
            } catch (error) {
                console.error('获取天气数据失败:', error);
                errorMessage.textContent = `无法获取天气数据: ${error.message}`;
                errorMessage.style.display = 'block';
                
                // 清空所有天气数据
                for (let i = 0; i < 3; i++) {
                    document.getElementById(`weatherDay${i}`).textContent = "--";
                    document.getElementById(`minTempDay${i}`).textContent = "--°";
                    document.getElementById(`maxTempDay${i}`).textContent = "--°";
                    document.querySelectorAll('.weather-icon')[i].innerHTML = `<i class="fas fa-question"></i>`;
                }
            } finally {
                // 隐藏加载动画
                loader.classList.remove('active');
            }
        }
        
        // 打开日历应用
        function openCalendarApp() {
            try {
                // 使用Intent打开日历应用
                const intentUrl = `intent://com.android.calendar.AllInOneActivity#Intent;scheme=launcher;package=com.coloros.calendar;component=com.coloros.calendar/com.android.calendar.AllInOneActivity;end`;
                window.location.href = intentUrl;
                
                console.log('正在打开日历应用...');
            } catch (e) {
                console.error('打开日历应用失败:', e);
                alert('打开日历应用失败，请确保已安装日历应用');
            }
        }
        
        // 打开天气应用
        function openWeatherApp() {
            try {
                // 使用Intent打开天气应用
                const intentUrl = `intent://com.oplus.weather.main.view.WeatherMainActivity#Intent;scheme=launcher;package=com.coloros.weather2;component=com.coloros.weather2/com.oplus.weather.main.view.WeatherMainActivity;end`;
                window.location.href = intentUrl;
                
                console.log('正在打开天气应用...');
            } catch (e) {
                console.error('打开天气应用失败:', e);
                alert('打开天气应用失败，请确保已安装天气应用');
            }
        }
        
        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            // 初始加载数据
            fetchWeatherData();
            
            // 第一个卡片点击打开日历应用
            document.getElementById('day0').addEventListener('click', () => {
                openCalendarApp();
            });
            
            // 第二个卡片双击刷新
            const day1Card = document.getElementById('day1');
            let lastTap = 0;
            day1Card.addEventListener('click', () => {
                const currentTime = new Date().getTime();
                const tapLength = currentTime - lastTap;
                
                // 判断是否为双击（300ms内两次点击）
                if (tapLength < 300 && tapLength > 0) {
                    fetchWeatherData();
                    // 添加视觉反馈
                    day1Card.style.transform = 'scale(0.95)';
                    setTimeout(() => {
                        day1Card.style.transform = '';
                    }, 200);
                }
                
                lastTap = currentTime;
            });
            
            // 第三个卡片点击打开天气应用
            document.getElementById('day2').addEventListener('click', () => {
                openWeatherApp();
            });
        });
    </script>




